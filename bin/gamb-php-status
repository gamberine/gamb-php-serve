#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$script_dir/../lib/gamb-php-common.sh" ]; then
  export GAMB_PHP_SHARE_DIR="${GAMB_PHP_SHARE_DIR:-$script_dir/../share}"
  export GAMB_PHP_DASHBOARD_DIR="${GAMB_PHP_DASHBOARD_DIR:-$script_dir/../share/dashboard}"
  export GAMB_PHP_ASSETS_DIR="${GAMB_PHP_ASSETS_DIR:-$script_dir/../docs/assets}"
  # shellcheck disable=SC1091
  source "$script_dir/../lib/gamb-php-common.sh"
elif [ -f "$HOME/.config/gamb-php/lib/gamb-php-common.sh" ]; then
  # shellcheck disable=SC1091
  source "$HOME/.config/gamb-php/lib/gamb-php-common.sh"
else
  printf '%s\n' 'Biblioteca gamb-php-common.sh não encontrada.' >&2
  exit 1
fi

show_all=0

while [ $# -gt 0 ]; do
  case "$1" in
    --all)
      show_all=1
      shift
      ;;
    --help|-h)
      gamb_php_print_usage_status
      exit 0
      ;;
    *)
      printf 'Argumento desconhecido: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

gamb_php_ensure_dirs

print_row_status() {
  local row="$1"
  local slug path type host port docroot index pid
  IFS=$'\t' read -r slug path type host port docroot index <<EOF
$row
EOF
  pid="$(gamb_php_running_state_for_row "$slug" || true)"
  gamb_php_format_row "$slug" "$path" "$type" "$host" "$port" "$docroot" "$index" "$pid"
  printf '\n'
}

if [ "$show_all" -eq 1 ]; then
  if [ -f "$gamb_php_projects_file" ]; then
    while IFS= read -r row; do
      [ -z "$row" ] && continue
      print_row_status "$row"
    done < "$gamb_php_projects_file"
  fi
  exit 0
fi

rows="$(gamb_php_find_registered_rows_for_cwd "$(gamb_php_current_dir)")" || {
  printf '%s\n' 'Projeto não registrado nesta pasta.' >&2
  exit 1
}

while IFS= read -r row; do
  [ -z "$row" ] && continue
  print_row_status "$row"
done <<EOF
$rows
EOF
